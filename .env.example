# ============================================================================
# Tradosphere V3.1 — environment template
# Copy to `.env` (gitignored) and fill in real values for local dev.
# In production these are set in the Render dashboard (see render.yaml).
# Variable names below MATCH exactly what the code reads via os.getenv().
# ============================================================================

# ===== FLASK SERVER =====
FLASK_ENV=production            # 'production' enables prod gates; 'development' for local
ENVIRONMENT=production
PORT=5000
DEBUG=False

# ===== SECURITY (app fails fast if these are weak/missing in production) =====
# Generate each:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=<generate-strong-secret-key>
JWT_SECRET=<generate-strong-secret-key>

# ===== DATABASE =====
DATABASE_URL=postgresql://user:password@localhost:5432/tradosphere

# ===== ANGEL ONE SMARTAPI (live market data) =====
ANGEL_ONE_API_KEY=<your-api-key>
ANGEL_ONE_CLIENT_CODE=<your-client-code>
ANGEL_ONE_PIN=<your-pin>
ANGEL_ONE_TOTP_SECRET=<your-totp-secret>

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=<your-client-id>

# ===== STRIPE PAYMENTS (use LIVE keys in production) =====
STRIPE_API_KEY=<your-stripe-secret-key>          # sk_live_… in prod
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>   # pk_live_… in prod

# ===== EMAIL (SendGrid OR SMTP) =====
SENDGRID_API_KEY=<your-sendgrid-key>
FROM_EMAIL=noreply@tradosphere.com
# --- SMTP alternative (only if not using SendGrid) ---
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=<your-email>
# SENDER_PASSWORD=<your-app-password>

# ===== CLAUDE AI =====
ANTHROPIC_API_KEY=<your-anthropic-key>

# ===== CACHE / RATE-LIMIT STORE (optional; fails open if unset) =====
REDIS_URL=                      # e.g. redis://default:pass@host:6379

# ===== APPLICATION =====
APP_VERSION=3.1.0
# Comma-separated production frontend origins added to the CORS allow-list:
CORS_ORIGINS=https://yourdomain.com
LOG_DIR=/tmp/tradosphere-logs   # writable path for file logs (best-effort)
LOG_LEVEL=INFO

# ===== ERROR TRACKING (optional, recommended) =====
SENTRY_DSN=
